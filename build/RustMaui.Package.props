<Project>
  <PropertyGroup>
    <RustMauiPackageVersion>1.0.0.3</RustMauiPackageVersion>
    <RustMauiPackageAuthors>Nick Kovalsky aka AppoMobi and contributors</RustMauiPackageAuthors>
    <RustMauiPackageProjectUrl>https://github.com/taublast/RustMaui</RustMauiPackageProjectUrl>
    <RustMauiRepositoryUrl>https://github.com/taublast/RustMaui</RustMauiRepositoryUrl>
    <RustMauiRepositoryType>git</RustMauiRepositoryType>
    <RustMauiPackageLicenseExpression>MIT</RustMauiPackageLicenseExpression>
  </PropertyGroup>
</Project>