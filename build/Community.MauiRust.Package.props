<Project>
  <PropertyGroup>
    <CommunityMauiRustPackageVersion>1.0.0-pre12</CommunityMauiRustPackageVersion>
    <CommunityMauiRustPackageAuthors>Nick Kovalsky aka AppoMobi and contributors</CommunityMauiRustPackageAuthors>
    <CommunityMauiRustPackageProjectUrl>https://github.com/taublast/RustMaui</CommunityMauiRustPackageProjectUrl>
